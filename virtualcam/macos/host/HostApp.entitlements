<?xml version="1.0" encoding="UTF-8"?>
<!-- SPDX-License-Identifier: Apache-2.0 -->
<!-- AK Virtual Camera — Host app entitlements (Phase 4 scaffold, VERIFY).
     The host app submits the system-extension install request on the
     user's behalf. VERIFY the entitlement keys against Apple's sample. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>com.apple.security.app-sandbox</key>
    <false/>

    <!-- VERIFY: entitlement to install system extensions. -->
    <key>com.apple.developer.system-extension-install</key>
    <true/>

    <!-- The host app also writes frames to the POSIX shm ring when no
         Python producer is connected (placeholder publisher). It therefore
         needs to create the shared region with broad permissions. -->
    <key>com.apple.security.temporary-exception.files.absolute-path.read-write</key>
    <array>
        <string>/tmp/</string>
    </array>
</dict>
</plist>
