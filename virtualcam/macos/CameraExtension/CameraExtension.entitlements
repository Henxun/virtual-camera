<?xml version="1.0" encoding="UTF-8"?>
<!-- SPDX-License-Identifier: Apache-2.0 -->
<!-- AK Virtual Camera — Camera Extension entitlements (Phase 4 scaffold, VERIFY).
     The exact entitlement keys for a Camera Extension must be confirmed
     against Apple's sample + your Developer account's allowed entitlements. -->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- VERIFY: the camera-extension entitlement key name. Likely one of:
         com.apple.developer.camera-extension
         com.apple.developer.coremediaio.camera-extension
         Confirm in the Apple sample / your provisioning profile. -->
    <key>com.apple.developer.camera-extension</key>
    <true/>

    <!-- Sandbox: Camera Extensions run sandboxed. We need to read POSIX shm
         created by a user-process. Whether the sandbox permits shm_open()
         of "/akvc-frames-v1" is the #1 risk of Phase 4 — see
         docs/phase4/implementation-plan.md Plan B. If blocked, switch the
         IPC to XPC + IOSurface. -->
    <key>com.apple.security.app-sandbox</key>
    <true/>

    <!-- VERIFY: temporary-exception to access POSIX shared memory if the
         sandbox blocks shm_open. Remove if the primary path works. -->
    <key>com.apple.security.temporary-exception.mach-lookup.global-name</key>
    <array/>
</dict>
</plist>
